model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  phone     String?
  password  String
  verified  Boolean   @default(false)
  disabled  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Includes
  tokens    Token[]

  // References
  

  // Relationships

}