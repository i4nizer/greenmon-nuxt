model Token {
    id        Int       @id @default(autoincrement())
    token     String    @db.VarChar(512)
    type      TokenType
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    // References: Conditionally required based on TokenType
    userId    Int?

    // Relationships
    user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints
    @@unique([userId, type])
}

enum TokenType {
    VERIFY
    REFRESH
    RESET
    MCU
    CAMERA
    GREENHOUSE
}